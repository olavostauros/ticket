---
export const prerender = false;

import BaseLayout from "../../../layouts/BaseLayout.astro";
import { query } from "../../../lib/db";

const { ref } = Astro.params;
const regResult = await query("SELECT * FROM registrations WHERE reference = $1", [ref]);
const registration = regResult.rows[0];
if (!registration) return Astro.redirect("/404");
---
<BaseLayout title="Inscrição confirmada — Ticket">
  <main style="max-width: 560px; margin: 0 auto; padding: 48px 24px; text-align: center;">
    <h1 style="font-size: 2rem; margin: 0;">🎉 Inscrição confirmada!</h1>
    <p style="color: #666; margin-top: 8px;">Sua inscrição foi processada com sucesso.</p>
    <div style="background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 12px; padding: 24px; margin-top: 24px;">
      <p style="margin: 0;"><strong>Inscrição:</strong> {registration.reference}</p>
      <p style="margin: 8px 0;"><strong>Email:</strong> {registration.attendee_email}</p>
      <p style="margin: 8px 0;"><strong>Status:</strong> {registration.status === "confirmed" ? "✅ Confirmada" : "❌ Cancelada"}</p>
    </div>
    {registration.status !== "confirmed" && (
      <p style="color: #888; margin-top: 16px;">Sua inscrição está cancelada. Entre em contato com o organizador para mais informações.</p>
    )}
    <a href="/" style="display: inline-block; margin-top: 24px; color: #1a73e8;">Voltar para o início</a>
  </main>
</BaseLayout>