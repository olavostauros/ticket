---
export const prerender = false;

import BaseLayout from "../../../layouts/BaseLayout.astro";
import { query } from "../../../lib/db";

const { ref } = Astro.params;
const orderResult = await query("SELECT * FROM orders WHERE reference = $1", [ref]);
const order = orderResult.rows[0];
if (!order) return Astro.redirect("/404");
---
<BaseLayout title="Compra confirmada — Ticket">
  <main style="max-width: 560px; margin: 0 auto; padding: 48px 24px; text-align: center;">
    <h1 style="font-size: 2rem; margin: 0;">🎉 Compra confirmada!</h1>
    <p style="color: #666; margin-top: 8px;">Seu pedido foi processado com sucesso.</p>
    <div style="background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 12px; padding: 24px; margin-top: 24px;">
      <p style="margin: 0;"><strong>Pedido:</strong> {order.reference}</p>
      <p style="margin: 8px 0;"><strong>Email:</strong> {order.attendee_email}</p>
      <p style="margin: 8px 0;"><strong>Status:</strong> {order.status === "paid" ? "✅ Pago" : "⏳ Pendente"}</p>
    </div>
    {order.status !== "paid" && (
      <p style="color: #888; margin-top: 16px;">Você receberá os ingressos por email após a confirmação do pagamento.</p>
    )}
    <a href="/" style="display: inline-block; margin-top: 24px; color: #1a73e8;">Voltar para o início</a>
  </main>
</BaseLayout>