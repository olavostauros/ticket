---
export const prerender = false;

import DashboardLayout from "../../../layouts/DashboardLayout.astro";
import { requireAuth } from "../../../lib/auth";
import { query } from "../../../lib/db";
const user = await requireAuth(Astro);
const slug = Astro.params.slug!;
const ev = (await query("SELECT * FROM events WHERE slug = $1 AND organizer_id = $2", [slug, user.id])).rows[0];
if (!ev) return Astro.redirect("/404");
const tiers = (await query("SELECT * FROM tiers WHERE event_id = $1 ORDER BY created_at ASC", [ev.id])).rows;
---
<DashboardLayout>
  <div style="display: flex; justify-content: space-between; align-items: start; margin-bottom: 24px;">
    <div>
      <h1 style="margin: 0;">{ev.title}</h1>
      <p style="color: #666; margin: 4px 0 0;">
        Status: {ev.status === "published" ? "✅ Publicado" : ev.status === "draft" ? "📝 Rascunho" : "❌ Cancelado"}
      </p>
    </div>
    <div style="display: flex; gap: 8px;">
      {ev.status === "draft" && (
        <>
          <form method="POST" action={`/api/events/${slug}/publish`}>
            <button type="submit" style="padding: 8px 16px; background: #16a34a; color: #fff; border: none; border-radius: 6px; cursor: pointer; font-size: 0.875rem;">Publicar</button>
          </form>
          <a href={`/dashboard/events/${slug}/edit`} style="padding: 8px 16px; border: 1px solid #e5e7eb; border-radius: 6px; font-size: 0.875rem; text-decoration: none;">Editar</a>
        </>
      )}
      <a href={`/events/${slug}`} style="padding: 8px 16px; border: 1px solid #e5e7eb; border-radius: 6px; font-size: 0.875rem;">Ver página pública</a>
    </div>
  </div>
  <hr style="margin: 24px 0;" />
  <h2 style="margin: 0 0 16px;">Ingressos</h2>
  {tiers.map((tier) => (
    <div key={tier.id} style="display: flex; justify-content: space-between; align-items: center; padding: 12px 16px; border: 1px solid #e5e7eb; border-radius: 6px; margin-bottom: 8px;">
      <div>
        <p style="margin: 0; font-weight: 600;">{tier.name}</p>
        <p style="margin: 4px 0 0; color: #666; font-size: 0.875rem;">
          {tier.quantity_sold}/{tier.quantity_total} inscritos
        </p>
      </div>
    </div>
  ))}
  {ev.status === "draft" && (
    <a href={`/dashboard/events/${slug}/tiers/new`} style="display: inline-block; margin-top: 8px; padding: 8px 16px; border: 1px dashed #ccc; border-radius: 6px; color: #666;">+ Adicionar ingresso</a>
  )}
  <hr style="margin: 24px 0;" />
  <div style="display: flex; gap: 12px;">
    <a href={`/dashboard/events/${slug}/dashboard`} style="padding: 10px 20px; background: #1a73e8; color: #fff; border-radius: 6px;">Dashboard de vendas</a>
    <a href={`/dashboard/events/${slug}/checkin`} style="padding: 10px 20px; border: 1px solid #e5e7eb; border-radius: 6px;">Check-in</a>
  </div>
</DashboardLayout>