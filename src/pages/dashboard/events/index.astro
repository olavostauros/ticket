---
export const prerender = false;

import DashboardLayout from "../../../layouts/DashboardLayout.astro";
import { requireAuth } from "../../../lib/auth";
import { query } from "../../../lib/db";
const user = await requireAuth(Astro);
const eventsResult = await query("SELECT * FROM events WHERE organizer_id = $1 ORDER BY created_at DESC", [user.id]);
const events = eventsResult.rows;
---
<DashboardLayout>
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
    <h1 style="margin: 0;">Eventos</h1>
    <a href="/dashboard/events/new" style="padding: 10px 20px; background: #1a73e8; color: #fff; border-radius: 6px; font-size: 0.875rem; font-weight: 600;">Criar Evento</a>
  </div>
  {events.length === 0 ? (
    <p style="color: #888;">Nenhum evento criado ainda.</p>
  ) : (
    <div style="display: flex; flex-direction: column; gap: 8px;">
      {events.map((ev) => (
        <a href={`/dashboard/events/${ev.slug}`} key={ev.id} style="display: flex; justify-content: space-between; align-items: center; padding: 16px; border: 1px solid #e5e7eb; border-radius: 8px; text-decoration: none; color: inherit;">
          <div>
            <p style="margin: 0; font-weight: 600;">{ev.title}</p>
            <p style="margin: 4px 0 0; color: #666; font-size: 0.875rem;">
              {ev.status === "published" ? "✅ Publicado" : ev.status === "draft" ? "📝 Rascunho" : "❌ Cancelado"}
            </p>
          </div>
          <span style="color: #888;">→</span>
        </a>
      ))}
    </div>
  )}
</DashboardLayout>