---
export const prerender = false;

import DashboardLayout from "../../../../layouts/DashboardLayout.astro";
import { requireAuth } from "../../../../lib/auth";
import { query } from "../../../../lib/db";
import { getEventDashboardStats } from "../../../../lib/dashboard";
const user = await requireAuth(Astro);
const slug = Astro.params.slug!;
const ev = (await query("SELECT * FROM events WHERE slug = $1 AND organizer_id = $2", [slug, user.id])).rows[0];
if (!ev) return Astro.redirect("/404");
const dashboardData = await getEventDashboardStats(ev.id);
const stats = dashboardData.stats;
---
<DashboardLayout>
  <a href={`/dashboard/events/${slug}`} style="color: #666; margin-bottom: 16px; display: inline-block;">← Voltar para o evento</a>
  <h1 style="margin: 0 0 24px;">Dashboard — {ev.title}</h1>
  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px;">
    <div style="padding: 20px; border: 1px solid #e5e7eb; border-radius: 8px;">
      <p style="margin: 0; color: #666; font-size: 0.875rem;">Pedidos Pagos</p>
      <p style="margin: 8px 0 0; font-size: 2rem; font-weight: 600;">{stats.total_orders}</p>
    </div>
    <div style="padding: 20px; border: 1px solid #e5e7eb; border-radius: 8px;">
      <p style="margin: 0; color: #666; font-size: 0.875rem;">Receita Total</p>
      <p style="margin: 8px 0 0; font-size: 2rem; font-weight: 600;">R$ {(stats.total_revenue_cents / 100).toFixed(2).replace(".", ",")}</p>
    </div>
    <div style="padding: 20px; border: 1px solid #e5e7eb; border-radius: 8px;">
      <p style="margin: 0; color: #666; font-size: 0.875rem;">Ingressos Vendidos</p>
      <p style="margin: 8px 0 0; font-size: 2rem; font-weight: 600;">{stats.total_tickets_sold}</p>
    </div>
    <div style="padding: 20px; border: 1px solid #e5e7eb; border-radius: 8px;">
      <p style="margin: 0; color: #666; font-size: 0.875rem;">Check-ins Realizados</p>
      <p style="margin: 8px 0 0; font-size: 2rem; font-weight: 600;">{stats.total_checked_in}</p>
    </div>
    <div style="padding: 20px; border: 1px solid #e5e7eb; border-radius: 8px;">
      <p style="margin: 0; color: #666; font-size: 0.875rem;">Capacidade Restante</p>
      <p style="margin: 8px 0 0; font-size: 2rem; font-weight: 600;">{stats.remaining_capacity}</p>
    </div>
  </div>
</DashboardLayout>