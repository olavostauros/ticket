---
export const prerender = false;

import DashboardLayout from "../../../../layouts/DashboardLayout.astro";
import { requireAuth } from "../../../../lib/auth";
import CheckinClient from "../../../../components/CheckinClient";
const user = await requireAuth(Astro);
const slug = Astro.params.slug!;
---
<DashboardLayout>
  <a href={`/dashboard/events/${slug}`} style="color: #666; margin-bottom: 16px; display: inline-block;">← Voltar para o evento</a>
  <h1 style="margin: 0 0 24px;">Check-in</h1>
  <CheckinClient client:load slug={slug} />
</DashboardLayout>