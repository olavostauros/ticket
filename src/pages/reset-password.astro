---
export const prerender = false;

import BaseLayout from "../layouts/BaseLayout.astro";
import ResetPasswordForm from "../components/ResetPasswordForm";

const token = Astro.url.searchParams.get("token") || "";
---
<BaseLayout title="Redefinir senha — Ticket">
  {token ? (
    <ResetPasswordForm token={token} client:load />
  ) : (
    <main style={{ maxWidth: 400, margin: "0 auto", padding: "4rem 1rem", textAlign: "center" }}>
      <h1 style={{ fontSize: "1.5rem", marginBottom: "0.5rem" }}>Link inválido</h1>
      <p style={{ color: "#666", marginBottom: "2rem" }}>
        O link de redefinição de senha está ausente ou é inválido.
      </p>
      <a href="/forgot-password" style={{ color: "#171717", textDecoration: "underline" }}>
        Solicitar novo link
      </a>
    </main>
  )}
</BaseLayout>