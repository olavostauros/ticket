---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout>
  <main style="max-width: 1200px; margin: 0 auto; padding: 24px;">
    <header style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 48px;">
      <h1 style="margin: 0; font-size: 1.5rem;">Ticket</h1>
      <nav style="display: flex; gap: 16px;">
        <a href="/login" style="padding: 8px 16px; border-radius: 6px; background: #171717; color: #fff;">Entrar</a>
      </nav>
    </header>
    <section style="text-align: center; padding: 80px 0;">
      <h2 style="font-size: 2.5rem; margin: 0 0 16px;">Venda ingressos para seus eventos</h2>
      <p style="font-size: 1.125rem; color: #666; max-width: 600px; margin: 0 auto 32px;">
        Crie, publique e venda ingressos online. Check-in por QR code na hora do evento.
      </p>
      <a href="/signup" style="display: inline-block; padding: 14px 32px; background: #1a73e8; color: #fff; border-radius: 8px; font-size: 1.125rem; font-weight: 600;">Criar conta gratuita</a>
    </section>
  </main>
</BaseLayout>