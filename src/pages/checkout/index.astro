---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";
import CheckoutForm from "../../components/CheckoutForm";

const eventSlug = Astro.url.searchParams.get("event") || "";
const tierId = Astro.url.searchParams.get("tier") || undefined;
---
<BaseLayout title="Checkout — Ticket">
  <main style="max-width: 560px; margin: 0 auto; padding: 24px;">
    <h1 style="margin: 0;">Finalizar Compra</h1>
    <CheckoutForm client:load eventSlug={eventSlug} tierId={tierId} />
  </main>
</BaseLayout>