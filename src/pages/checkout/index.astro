---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";
---
<BaseLayout title="Checkout — Ticket">
  <main style="max-width: 560px; margin: 0 auto; padding: 24px;">
    <h1 style="margin: 0;">Finalizar Compra</h1>
    <p style="color: #666; margin-top: 4px;">Checkout em construção. Use a API diretamente para testar.</p>
    <pre style="background: #f5f5f5; padding: 16px; border-radius: 8px; margin-top: 16px; font-size: 0.875rem;">
POST /api/checkout
{`{
  "event_id": "...",
  "items": [{ "tier_id": "...", "quantity": 1 }],
  "attendee_email": "...",
  "idempotency_key": "..."
}`}
    </pre>
  </main>
</BaseLayout>