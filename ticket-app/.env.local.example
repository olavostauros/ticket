# Supabase (required)
# For local Docker dev, run `supabase start` first and copy the values printed by the CLI.
# Or point to your Supabase cloud project.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AbacatePay (required for payments)
ABACATEPAY_API_KEY=apk_xxxxxxxxxxxx
ABACATEPAY_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
# Optional: AbacatePay API URL override (default: https://api.abacatepay.com/v1/billing/create)
# ABACATEPAY_API_URL=https://api.abacatepay.com/v1/billing/create

# Resend (required for transactional emails)
RESEND_API_KEY=re_xxxxxxxxxxxx
# Optional: Override the sender email (must be verified in Resend)
# RESEND_FROM_EMAIL=Ticket <noreply@yourdomain.com>

# Job processor (internal — protects /api/cron/process-jobs)
JOB_PROCESSOR_SECRET=generate-a-random-secret-here

# App URL (used in emails, redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Docker Development ─────────────────────────────────────
# The docker-compose.yml reads these variables from your .env file.
# Create a .env file (not .env.local — Docker Compose reads .env by default)
# with the values above. For local Supabase:
#
#   1. Run: supabase start
#   2. Copy the printed values (URL, anon key, service role key) into .env
#   3. Run: ./scripts/up.sh
#
# Docker Compose will also start PostgreSQL for schema bootstrapping.
# The app auto-reloads on source changes (hot module replacement).