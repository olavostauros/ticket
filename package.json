{
  "name": "ticket",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "postbuild": "cp dist/server/entry.mjs dist/_worker.js",
    "postbuild:cloudflare": "rm -rf dist/server/wrangler.json .wrangler && cp dist/server/entry.mjs dist/_worker.js && cp dist/server/virtual_astro_middleware.mjs dist/virtual_astro_middleware.mjs && rm -rf dist/chunks 2>/dev/null; mv dist/server/chunks dist/chunks",
    "start": "astro start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:smoke": "vitest run --reporter=verbose src/tests/smoke.suite.ts"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.1.1",
    "@astrojs/node": "^11.0.2",
    "@astrojs/react": "^6.0.0",
    "@neondatabase/serverless": "^1.1.0",
    "astro": "^7.0.5",
    "bcryptjs": "^3.0.3",
    "html5-qrcode": "^2.3.8",
    "jose": "^6.2.3",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "resend": "^6.16.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/bun": "latest",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5",
    "vitest": "^4.1.9",
    "wrangler": "^4.110.0"
  }
}