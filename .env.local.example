# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ticket

# Auth — generate with: openssl rand -base64 32
JWT_SECRET=change-me-in-production

# Payments — get from https://abacatepay.com
ABACATEPAY_API_KEY=apk_xxxxxxxxxxxx
ABACATEPAY_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# Email — get from https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx

# App URL
PUBLIC_APP_URL=http://localhost:4321

# Cron (Cloudflare Cron Triggers handle auth internally — no CRON_SECRET needed)
# For local dev, the cron endpoint is unprotected (Cron Triggers auth only in Cloudflare)
